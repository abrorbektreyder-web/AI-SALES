generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 📌 TASHKILOT (ORGANIZATION) - Zadarma API kalitlari va ATS sozlamalari
model Organization {
  id              String   @id @default(uuid())
  name            String
  
  // Zadarma API kalitlari (shifrlangan saqlanadi)
  zadarmApiKey    String?
  zadarmApiSecret String?
  zadarmSipBase   String?  // Masalan: "559324" (ATS prefix)
  
  users           User[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 📌 FOYDALANUVCHILAR (USER)
// 📌 BIR MARTALIK LOGIN KODLARI (FOR QR LOGIN)
model AccessToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id            String        @id @default(uuid())
  name          String
  phone         String        @unique
  email         String?
  company       String?
  password      String
  role          Role          @default(AGENT)
  averageScore  Float?
  
  // Zadarma ATS ichki raqami (masalan: 100, 101, 102...)
  sipExtension  String?
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  calls         CallRecord[]
  accessTokens  AccessToken[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum Role {
  ROP
  AGENT
}

// 📌 QO'NG'IROQLAR (CALL_RECORD)
model CallRecord {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  
  customerPhone String
  durationSec   Int
  audioUrl      String       
  status        CallStatus   @default(COMPLETED)
  
  analysis      AiAnalysis?
  
  createdAt     DateTime     @default(now())
}

enum CallStatus {
  COMPLETED
  ANALYZING
  FAILED
}

// 📌 AI TAHLILI (AI_ANALYSIS)
model AiAnalysis {
  id            String       @id @default(uuid())
  callId        String       @unique
  call          CallRecord   @relation(fields: [callId], references: [id], onDelete: Cascade)
  
  score         Int
  summary       String       @db.Text
  transcript    String?      @db.Text
  
  recommendedLessonId String?
  lesson              Lesson? @relation(fields: [recommendedLessonId], references: [id])
  
  createdAt     DateTime     @default(now())
}

// 📌 DARSLIKLAR / TAVSIYALAR (LESSON)
model Lesson {
  id            String       @id @default(uuid())
  title         String
  url           String
  type          String
  
  analyses      AiAnalysis[]
  
  createdAt     DateTime     @default(now())
}

